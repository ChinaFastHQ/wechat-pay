{
  "name": "@chinafast/expo-wechat-pay",
  "version": "0.1.0",
  "description": "Native WeChat App Pay for Expo and React Native applications.",
  "keywords": [
    "expo",
    "payments",
    "react-native",
    "wechat-pay"
  ],
  "homepage": "https://github.com/chinafast/china-pay#readme",
  "license": "MIT",
  "author": "ChinaFast",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chinafast/china-pay.git",
    "directory": "packages/expo-wechat-pay"
  },
  "files": [
    "dist",
    "android",
    "ios",
    "expo-module.config.json",
    "plugin.cjs",
    "plugin.js",
    "plugin.d.ts",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./plugin": {
      "types": "./plugin.d.ts",
      "import": "./plugin.js",
      "require": "./plugin.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@chinafast/core-wechat-pay": "workspace:^",
    "@expo/config-plugins": "^56.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "expo": "^56.0.0",
    "expo-modules-core": "^56.0.17",
    "react": "^19.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  },
  "peerDependencies": {
    "expo": ">=53",
    "expo-modules-core": "*",
    "react": ">=18",
    "react-native": ">=0.79"
  }
}
