{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "rules": {
    "no-await-in-loop": "off",
    "no-console": "off",
    "unicorn/no-array-sort": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/.pnpm-store/**"]
}
